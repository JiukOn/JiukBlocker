{
  "manifest_version": 3,
  "name": "JiukBlocker",
  "version": "0.7",
  "description": "Extension for content filtering in the Chromium ecosystem.",
  "permissions": [
    "storage",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "adblock_rules",
        "enabled": true,
        "path": "rules/net_rules.json"
      },
      {
        "id": "nsfw_rules",
        "enabled": false,
        "path": "rules/nsfw_rules.json"
      }
    ]
  },
  "background": {
    "service_worker": "background/service_worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.youtube.com/*"
      ],
      "css": [
        "content/Youtube/styles_youtube.css"
      ],
      "js": [
        "content/General/nsfw_keywords.js",
        "content/Youtube/content_youtube.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "*://*.instagram.com/*"
      ],
      "css": [
        "content/Instagram/styles_instagram.css"
      ],
      "js": [
        "content/General/nsfw_keywords.js",
        "content/Instagram/content_instagram.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "*://*.twitter.com/*",
        "*://*.x.com/*"
      ],
      "css": [
        "content/X/styles_x.css"
      ],
      "js": [
        "content/General/nsfw_keywords.js",
        "content/X/content_x.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "*://*.reddit.com/*"
      ],
      "css": [
        "content/Reddit/styles_reddit.css"
      ],
      "js": [
        "content/General/nsfw_keywords.js",
        "content/Reddit/content_reddit.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "*://*.tiktok.com/*"
      ],
      "css": [
        "content/TikTok/styles_tiktok.css"
      ],
      "js": [
        "content/General/nsfw_keywords.js",
        "content/TikTok/content_tiktok.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "<all_urls>"
      ],
      "exclude_matches": [
        "*://*.youtube.com/*",
        "*://*.instagram.com/*",
        "*://*.twitter.com/*",
        "*://*.x.com/*",
        "*://*.reddit.com/*",
        "*://*.tiktok.com/*"
      ],
      "css": [
        "content/General/styles_general.css"
      ],
      "js": [
        "content/General/nsfw_keywords.js",
        "content/General/ads_filter.js",
        "content/General/nsfw_filter.js",
        "content/General/content_general.js"
      ],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "assets/icon-16.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },
  "icons": {
    "16": "assets/icon-16.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  }
}